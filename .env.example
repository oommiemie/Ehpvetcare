# ─── AI service endpoints (BMS Cloud) ───
# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าตามสภาพแวดล้อม (ไฟล์ .env ถูก gitignore ไว้)
# หมายเหตุ: นี่เป็น static frontend — ค่าที่ตั้งจะถูก build เข้า bundle
#          หากต้องการซ่อน endpoint จริง ควรตั้ง proxy/gateway ที่มี auth แทน

VITE_AI_BASE=https://vllm-qwen.bmscloud.in.th
VITE_AI_BASE_BACKUP=https://vllm-gemma.bmscloud.in.th
VITE_AI_MODEL=qwen3.6

VITE_OCR_BASE=https://pdf-ocr-mcp.bmscloud.in.th/api

VITE_ASR_BASE=https://asr2.bmscloud.in.th
VITE_ASR_MODEL=Qwen/Qwen3-ASR-1.7B
VITE_TTS_BASE=https://vox-cpm.bmscloud.in.th
VITE_TTS_MODEL=voxcpm-thai
